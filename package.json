{
  "name": "sockdestroy",
  "version": "1.3.0",
  "description": "Native Node.js binding for killing TCP sockets via Linux netlink SOCK_DESTROY (ss -K equivalent)",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "gypfile": true,
  "files": [
    "lib/",
    "src/",
    "prebuilds/",
    "binding.gyp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kastov/sockdestroy.git"
  },
  "homepage": "https://github.com/kastov/sockdestroy#readme",
  "scripts": {
    "install": "node-gyp-build || true",
    "build": "node-gyp rebuild",
    "rebuild": "node-gyp rebuild",
    "test": "node --test test/test.mjs",
    "test:integration": "node --test test/integration.mjs",
    "test:benchmark": "node test/benchmark.mjs",
    "test:all": "node --test test/test.mjs && node --test test/integration.mjs && node test/benchmark.mjs",
    "prebuild:all": "./prebuild-all.sh"
  },
  "dependencies": {
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "node-gyp": "^12.2.0",
    "prebuildify": "^6.0.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT"
}
